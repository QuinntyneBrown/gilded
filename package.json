{
  "name": "gilded",
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm:dev:frontend\" \"npm:dev:backend\"",
    "seed:counsellors": "tsx backend/scripts/seed-counsellors.ts",
    "ingest:counsellors": "tsx backend/scripts/ingest-counsellors.ts",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend",
    "test": "npm run test --workspace backend",
    "test:lint": "node --import tsx --test tests/lint-fixtures/material-exclusivity.test.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "lint": "npm run lint --workspace frontend && eslint \"backend/**/*.ts\" \"e2e/**/*.ts\" playwright.config.ts",
    "lint:ui": "npm run lint:ui --workspace frontend",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "npm run typecheck --workspace frontend",
    "typecheck:backend": "npm run typecheck --workspace backend",
    "postinstall": "playwright install chromium webkit firefox"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "angular-eslint": "21.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "stylelint": "^17.8.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.4"
  }
}
