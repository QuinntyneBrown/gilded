{
  "name": "gilded",
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "cd frontend && ng serve",
    "dev:backend": "tsx watch backend/src/server.ts",
    "build": "cd frontend && ng build",
    "test": "node --import tsx --test backend/src/server.test.ts",
    "e2e": "playwright test",
    "lint": "cd frontend && ng lint && cd .. && eslint \"backend/**/*.ts\" \"e2e/**/*.ts\" playwright.config.ts",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "cd frontend && ng build",
    "typecheck:backend": "tsc --noEmit -p backend/tsconfig.json",
    "postinstall": "playwright install chromium"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.19",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.20",
    "@angular/cli": "^20.3.20",
    "@angular/compiler-cli": "^20.3.0",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^25.6.0",
    "angular-eslint": "21.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.4"
  }
}
